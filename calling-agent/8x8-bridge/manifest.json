{
  "manifest_version": 3,
  "name": "CallForge 8x8 Bridge",
  "version": "1.0.0",
  "description": "Lets the local CallForge page open 8x8 Work and try to dial/end calls.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://work.8x8.com/*",
    "http://127.0.0.1:5178/*",
    "http://localhost:5178/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:5178/*", "http://localhost:5178/*"],
      "js": ["callforge-page.js"]
    },
    {
      "matches": ["https://work.8x8.com/*"],
      "js": ["eightx8-page.js"]
    }
  ]
}
